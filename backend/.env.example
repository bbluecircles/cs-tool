# MariaDB service-account connection.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=cs_tool_svc
DB_PASSWORD=change_me
DB_DEFAULT_SCHEMA=myuser

# Auth
JWT_SECRET=change_me_to_a_long_random_value
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7
ADMIN_CUSTOMER_CODE=717
LEGACY_PW_PREFIX_KEY=forget1c#

# --- Feature flags ---
# If true, inline edits open a confirm-changes modal before applying.
# If false, edits commit directly on blur/Enter.
ENABLE_EDIT_CONFIRMATION=false

# If true, writes trigger the refresh_all() routine that rebuilds the
# denormalized user_details* views. Default false because an external
# process handles this.
ENABLE_VIEW_REFRESH=false

# CORS / cookies
CORS_ORIGINS=http://localhost:5173
COOKIE_SECURE=false
COOKIE_DOMAIN=

# App
APP_ENV=development
LOG_LEVEL=INFO
